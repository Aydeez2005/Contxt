# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=          
DATABASE_URL=           

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         

# ── Redis (optional — falls back to in-memory if unset) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Server ────────────────────────────────────────────────
BASE_URL=https://mon-put-yourself-threatened.trycloudflare.com # free tunnel service from cloudflare the link changes as you refresh the server
PORT=3000
NODE_ENV=development

# ── OAuth — Slack ──────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Callback: $BASE_URL/oauth/callback/slack

# ── OAuth — Linear ────────────────────────────────────────
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
# Callback: $BASE_URL/oauth/callback/linear

# ── OAuth — GitHub ────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Callback: $BASE_URL/oauth/callback/github

# ── OAuth — Google Calendar ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback: $BASE_URL/oauth/callback/gcal

# ── OAuth — Jira (Atlassian) ──────────────────────────────
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Callback: $BASE_URL/oauth/callback/jira
